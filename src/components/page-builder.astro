---
import type { PageBuilder as PageBuilderType, EVENTS_QUERY_RESULT } from "../sanity/types";
import { Hero } from "./blocks/hero/index";
import { SplitImage } from "./blocks/split-image";
import { Prose } from "./blocks/prose";
import { Events } from "./blocks/events";
import { Team } from "./blocks/team";
import { sanityFetch } from "../lib/client";
import { EVENTS_QUERY } from "../lib/queries";
import { tryCatch } from "../utils/try-catch";

interface Props {
  content: PageBuilderType;
}

const { content } = Astro.props;

// Pre-fetch events if any block needs them
const hasEventsBlock = content.some((block) => block._type === "events");
let events: EVENTS_QUERY_RESULT = [];

if (hasEventsBlock) {
  const result = await tryCatch(
    sanityFetch<EVENTS_QUERY_RESULT>({ query: EVENTS_QUERY }),
  );

  if (result.error) {
    console.error("Failed to fetch events:", result.error);
  } else {
    events = result.data;
  }
}
---

{
  content.map((block, index) => {
    const isLast = index === content.length - 1;

    return (
      <div class={isLast ? undefined : "border-b"}>
        {block._type === "hero" && <Hero block={block} />}
        {block._type === "splitImage" && <SplitImage block={block} />}
        {block._type === "prose" && <Prose block={block} />}
        {block._type === "events" && <Events block={block} events={events} />}
        {block._type === "team" && <Team block={block} />}
      </div>
    );
  })
}
