---
import AppLayout from "../../layouts/AppLayout.astro";
import { EventComponent } from "../../components/event";
import { EVENT_BY_SLUG_QUERY, EVENTS_SLUGS_QUERY } from "../../lib/queries";
import { sanityFetch } from "../../lib/client";
import type { EVENT_BY_SLUG_QUERY_RESULT, EVENTS_SLUGS_QUERY_RESULT } from "../../sanity/types";
import { getSeoMeta } from "../../lib/seo";

export async function getStaticPaths() {
  const slugs = await sanityFetch<EVENTS_SLUGS_QUERY_RESULT>({
    query: EVENTS_SLUGS_QUERY,
  });

  return slugs.map((event) => ({
    params: { slug: event.slug },
  }));
}

const { slug } = Astro.params;

const event = await sanityFetch<EVENT_BY_SLUG_QUERY_RESULT>({
  query: EVENT_BY_SLUG_QUERY,
  params: { slug },
});

if (!event) {
  return Astro.redirect("/404");
}

const seo = getSeoMeta({ slug: { _type: "slug", current: `/events/${slug}` }, seo: event.seo });
---

<AppLayout
  title={seo.title}
  description={seo.description}
  robots={seo.robots}
  canonical={seo.canonical}
  openGraph={seo.openGraph}
>
  <EventComponent event={event} />
</AppLayout>
