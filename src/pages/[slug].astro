---
import AppLayout from "../layouts/AppLayout.astro";
import PageBuilder from "../components/page-builder.astro";
import { PAGE_QUERY, PAGES_SLUGS_QUERY } from "../lib/queries";
import { sanityFetch } from "../lib/client";
import type { PAGE_QUERY_RESULT, PAGES_SLUGS_QUERY_RESULT } from "../sanity/types";
import { getPageDescription, getPageTitle, getSeoMeta } from "../lib/seo";

export async function getStaticPaths() {
  const slugs = await sanityFetch<PAGES_SLUGS_QUERY_RESULT>({
    query: PAGES_SLUGS_QUERY,
  });

  return slugs
    .filter((page) => page.slug !== "home")
    .map((page) => ({
      params: { slug: page.slug },
    }));
}

const { slug } = Astro.params;

const page = await sanityFetch<PAGE_QUERY_RESULT>({
  query: PAGE_QUERY,
  params: { slug },
});

if (!page) {
  return Astro.redirect("/404");
}

const seo = getSeoMeta({
  pathname: `/${slug}`,
  title: getPageTitle(page.content, page.title),
  description: getPageDescription(page.content),
  ogPath: `/og/${slug}.png`,
});
---

<AppLayout
  title={seo.title}
  description={seo.description}
  robots={seo.robots}
  canonical={seo.canonical}
  openGraph={seo.openGraph}
>
  <PageBuilder content={page.content} />
</AppLayout>
